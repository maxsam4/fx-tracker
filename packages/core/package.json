{
  "name": "@fx/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./db": "./src/db/index.ts",
    "./providers": "./src/providers/index.ts",
    "./alerts": "./src/alerts/index.ts",
    "./config": "./src/config/index.ts",
    "./scrape": "./src/scrape/index.ts",
    "./telegramBot": "./src/telegramBot/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "FX_LIVE=1 vitest run test/live/providers.live.test.ts",
    "test:live:scrape": "FX_LIVE_SCRAPE=1 vitest run test/live/scrapers.live.test.ts",
    "test:live:scrape:fragile": "FX_LIVE_SCRAPE=1 FX_LIVE_SCRAPE_FRAGILE=1 vitest run test/live/scrapers.live.test.ts",
    "test:live:all": "FX_LIVE=1 FX_LIVE_SCRAPE=1 FX_LIVE_SCRAPE_FRAGILE=1 vitest run test/live",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.0",
    "postgres": "^3.4.4",
    "zod": "^3.23.8",
    "yaml": "^2.6.0",
    "pino": "^9.4.0",
    "playwright": "^1.48.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "node-cron": "^3.0.3",
    "bcrypt": "^5.1.1",
    "iron-session": "^8.0.4"
  },
  "devDependencies": {
    "drizzle-kit": "^0.28.0",
    "@types/bcrypt": "^5.0.2",
    "@types/node-cron": "^3.0.11"
  }
}
