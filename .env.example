# Postgres
POSTGRES_USER=fxtracker
POSTGRES_PASSWORD=replace_me
POSTGRES_DB=fxtracker
DATABASE_URL=postgres://fxtracker:replace_me@postgres:5432/fxtracker

# Web
WEB_PORT=3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Admin auth (hash with: node -e 'console.log(require("bcrypt").hashSync("yourpw",12))')
ADMIN_PASSWORD_HASH=
SESSION_SECRET=replace_me_with_32_plus_random_chars_xxxxxxxxxx

# Worker
POLL_INTERVAL_CRON=0 * * * *           # hourly at :00
ALERT_TICK_CRON=*/1 * * * *            # every minute (interval-rule evaluator)
NODE_ENV=development

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=                # for provider-failure self-alerts

# Public site
SITE_DOMAIN=fx.example.com             # used by Caddy in production
